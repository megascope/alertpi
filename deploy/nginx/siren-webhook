limit_req_zone $binary_remote_addr zone=trigger:10m rate=5r/m;

server {
    listen 127.0.0.1:8080;
    server_name _;

    # Block /docs and schema endpoints
    location ~ ^/(docs|openapi\.json|redoc) {
        return 404;
    }

    # Only allow POST /trigger
    location = /trigger {
        if ($request_method != POST) {
            return 405;
        }

        limit_req zone=trigger burst=2 nodelay;

        # Reject requests with no Authorization header before hitting FastAPI
        if ($http_authorization = "") {
            return 401;
        }

        # Prefer CF-Connecting-IP (set by cloudflared) over X-Forwarded-For
        set $client_ip $remote_addr;
        if ($http_cf_connecting_ip != "") {
            set $client_ip $http_cf_connecting_ip;
        }
        proxy_set_header X-Real-IP        $client_ip;
        proxy_set_header X-Forwarded-For  $client_ip;
        proxy_set_header Host             $host;

        proxy_pass http://127.0.0.1:8000;
        proxy_read_timeout 30s;
        proxy_connect_timeout 5s;
    }

    # Block everything else
    location / {
        return 404;
    }
}
