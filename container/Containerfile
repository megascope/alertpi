FROM python:3.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
        && apt-get install -y --no-install-recommends \
            build-essential \
            python3-dev \
            swig \
        && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

COPY pyproject.toml README.md /app/
COPY src /app/src

RUN uv sync --no-dev --extra pi

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "siren_driver.main:app", "--host", "0.0.0.0", "--port", "8000"]
